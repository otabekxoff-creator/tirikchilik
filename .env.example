# Admin Credentials - CHANGE THESE IN PRODUCTION!
ADMIN_LOGIN=your_admin_username_here
ADMIN_PASSWORD=your_secure_password_here

# Feature Flags
FIREBASE_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false
ANALYTICS_ENABLED=true

# Firebase Configuration (Required when FIREBASE_ENABLED=true)
# Get these from Firebase Console -> Project Settings -> General -> Your Apps
FIREBASE_API_KEY=your_api_key_here
FIREBASE_APP_ID=your_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# AdMob Configuration - TEST IDs (Replace with production IDs before release)
# Get these from AdMob Console -> Apps -> App Settings -> App ID
ADMOB_APP_ID=ca-app-pub-3940256099942544~3347511713
ADMOB_BANNER_ID=ca-app-pub-3940256099942544/6300978111
ADMOB_INTERSTITIAL_ID=ca-app-pub-3940256099942544/1033173712
ADMOB_REWARDED_ID=ca-app-pub-3940256099942544/5224354917

# App Configuration
ENABLE_DEBUG_LOGS=false
CACHE_ENABLED=true
OFFLINE_MODE=true
